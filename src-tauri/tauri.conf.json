{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VelocityUI",
  "version": "1.2.2",
  "identifier": "com.velocityui.dev",
  "build": {
    "frontendDist": "../resources"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "VelocityUI",
        "url": "Index.html",
        "width": 1100,
        "height": 720,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "center": true,
        "visible": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "devtools": true,
        "dragDropEnabled": false
      },
      {
        "label": "popover",
        "title": "",
        "url": "popover/index.html",
        "width": 320,
        "height": 450,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "shadow": false,
        "focus": false
      }
    ],
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/app.icns",
      "icons/app.png"
    ],
    "resources": {
      "../resources/Assets/": "Assets/",
      "../resources/BaseFiles/": "BaseFiles/",
      "icons/tray.png": "icons/tray.png"
    },
    "macOS": {
      "minimumSystemVersion": "10.13",
      "entitlements": null,
      "signingIdentity": null
    }
  }
}
